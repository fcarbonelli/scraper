# =============================================================================
# Runtime
# =============================================================================
NODE_ENV=development
LOG_LEVEL=debug
TZ=America/Argentina/Buenos_Aires

# =============================================================================
# Database (Supabase)
# =============================================================================
# From Supabase project settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# =============================================================================
# Redis (BullMQ queue backbone)
# =============================================================================
# Local: redis://localhost:6379
# Hosted: rediss://default:password@host:port
REDIS_URL=redis://localhost:6379

# =============================================================================
# API server
# =============================================================================
API_PORT=3000

# =============================================================================
# Scraping
# =============================================================================
# Cron expression for the daily scrape (in TZ above)
SCRAPE_CRON=0 6 * * *
# Weekly coverage sweep: re-search MISSING catalog EANs at every searchable
# chain to pick up products that came back in stock. Default: Sunday 02:00.
SWEEP_CRON=0 2 * * 0
# Default per-supermarket fallbacks (DB overrides these)
DEFAULT_RATE_LIMIT_MS=500
DEFAULT_CONCURRENCY=3

# =============================================================================
# Revista (magazine) pipeline — AI reads promo PDFs/flipbooks for chains that
# don't publish prices on the web (Makro, Vital, Rosental, Maxicomodín).
# See src/revistas/ and docs/REVISTA_REVIEW.md.
# =============================================================================
# Required for the magazine check to run (vision extraction + matching). Leave
# empty to disable the pipeline (the orchestrator logs a warning and skips it).
OPENAI_API_KEY=
# Models / tuning (sensible defaults; override only if needed).
REVISTA_VISION_MODEL=gpt-4o
REVISTA_JUDGE_MODEL=gpt-4o-mini
REVISTA_EMBEDDING_MODEL=text-embedding-3-small
# Min judge confidence (0–1) to queue a match. Low on purpose — the human is the
# real filter.
REVISTA_MATCH_THRESHOLD=0.3
# Bounded concurrency for vision/judge calls (stay under OpenAI rate limits).
REVISTA_CONCURRENCY=5
# Supabase Storage bucket for rendered page images (auto-created, public).
REVISTA_STORAGE_BUCKET=revista-pages
# Toggle the daily magazine check inside the orchestrator: "true" | "false".
REVISTA_ENABLED=true

# =============================================================================
# Observability
# =============================================================================
# Leave empty to disable Sentry
SENTRY_DSN=

# =============================================================================
# Notifications (Telegram)
# =============================================================================
# Create a bot via @BotFather, get the token. Then send a message to the bot
# and call https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Minimum severity to send to Telegram: "info" | "warning" | "critical"
TELEGRAM_MIN_SEVERITY=warning

# =============================================================================
# Per-supermarket auth (optional)
# =============================================================================
# Carrefour Maxi Pedido (comerciante.carrefour.com.ar) hides prices behind a
# logged-in session bound to a `PHPSESSID` cookie. The adapter SELF-HEALS:
# when the cookie expires it spawns headless Chromium (Playwright), submits
# the public "comerciante" registration form (which clears reCAPTCHA in a
# real browser), harvests the new cookie, and writes it to
# `supermarkets.config.phpSessId` so all workers pick it up. No cron needed.
#
# This env var is therefore OPTIONAL — leave empty for the very first run
# (the adapter will log in automatically and seed the DB on the first scrape).
# Set it only if you want to:
#   - bootstrap with a known cookie to skip the first auto-login, or
#   - override the DB-stored value temporarily during local debugging.
MAXI_CARREFOUR_PHPSESSID=
