# =============================================================================
# Runtime
# =============================================================================
NODE_ENV=development
LOG_LEVEL=debug
TZ=America/Argentina/Buenos_Aires

# =============================================================================
# Database (Supabase)
# =============================================================================
# From Supabase project settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# =============================================================================
# Redis (BullMQ queue backbone)
# =============================================================================
# Local: redis://localhost:6379
# Hosted: rediss://default:password@host:port
REDIS_URL=redis://localhost:6379

# =============================================================================
# API server
# =============================================================================
API_PORT=3000

# =============================================================================
# Scraping
# =============================================================================
# Cron expression for the daily scrape (in TZ above)
SCRAPE_CRON=0 6 * * *
# Default per-supermarket fallbacks (DB overrides these)
DEFAULT_RATE_LIMIT_MS=500
DEFAULT_CONCURRENCY=3

# =============================================================================
# Observability
# =============================================================================
# Leave empty to disable Sentry
SENTRY_DSN=

# =============================================================================
# Notifications (Telegram)
# =============================================================================
# Create a bot via @BotFather, get the token. Then send a message to the bot
# and call https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Minimum severity to send to Telegram: "info" | "warning" | "critical"
TELEGRAM_MIN_SEVERITY=warning
